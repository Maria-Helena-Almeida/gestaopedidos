<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu de Pedidos"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"
        android:textColor="#333333" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/chkCafe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Café (1.00€)"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtQtdCafe"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:hint="0"
            android:inputType="number"
            android:enabled="false"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/txtSubCafe"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="0.00€"
            android:textAlignment="viewEnd"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/chkPao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pão (0.50€)"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtQtdPao"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:hint="0"
            android:inputType="number"
            android:enabled="false"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/txtSubPao"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="0.00€"
            android:textAlignment="viewEnd"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="15dp"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/chkChoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chocolate (1.20€)"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edtQtdChoc"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:hint="0"
            android:inputType="number"
            android:enabled="false"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/txtSubChoc"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="0.00€"
            android:textAlignment="viewEnd"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnPedir"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="EFETUAR PEDIDO"
        android:layout_marginTop="40dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>